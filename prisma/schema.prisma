generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Tenants & Core Entities
model Employer {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String     @db.VarChar(255)
  payDay             Int        //between 1 and 28 (enforced at app level)
  maxWithdrawalPct   Decimal    @default(50.00) @db.Decimal(5, 2)
  createdAt          DateTime   @default(now()) @db.Timestamptz

  employees          Employee[]
  payCycles          PayCycle[]

  @@map("employers")
}

model Employee {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employerId         String              @db.Uuid
  fullName           String              @db.VarChar(255)
  monthlySalary      Decimal             @db.Decimal(12, 2)
  hireDate           DateTime            @db.Date
  status             String              @default("active") @db.VarChar(20)
  createdAt          DateTime            @default(now()) @db.Timestamptz

  employer           Employer            @relation(fields: [employerId], references: [id])
  withdrawalRequests WithdrawalRequest[]

  @@map("employees")
}

model PayCycle {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employerId         String            @db.Uuid
  periodStart        DateTime          @db.Date
  periodEnd          DateTime          @db.Date
  status             String            @default("open") @db.VarChar(20) // open, settling, closed

  employer           Employer          @relation(fields: [employerId], references: [id])
  withdrawalRequests WithdrawalRequest[]
  settlementBatch    SettlementBatch?

  @@unique([employerId, periodStart])
  @@map("pay_cycles")
}

// The Transactional Core
model WithdrawalRequest {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId         String         @db.Uuid
  payCycleId         String         @db.Uuid
  amount             Decimal        @db.Decimal(12, 2)
  feeAmount          Decimal        @default(0) @db.Decimal(12, 2)
  status             String         @default("pending") @db.VarChar(20)
  idempotencyKey     String         @db.VarChar(64)
  createdAt          DateTime       @default(now()) @db.Timestamptz

  employee           Employee       @relation(fields: [employeeId], references: [id])
  payCycle           PayCycle       @relation(fields: [payCycleId], references: [id])
  ledgerEntries      LedgerEntry[]

  //Prevents duplicate double-submit network retries
  @@unique([employeeId, idempotencyKey])
  @@map("withdrawal_requests")
}

// Immutable append-only double-entry ledger
model LedgerEntry {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  withdrawalRequestId   String            @db.Uuid
  accountType           String            @db.VarChar(30) // 'employee_balance' or 'employer_payable'
  accountRefId          String            @db.Uuid        // employee_id or employer_id
  entryType             String            @db.VarChar(10) // 'debit' or 'credit'
  amount                Decimal           @db.Decimal(12, 2)
  createdAt             DateTime          @default(now()) @db.Timestamptz

  withdrawalRequest     WithdrawalRequest @relation(fields: [withdrawalRequestId], references: [id])

  @@map("ledger_entries")
}

model SettlementBatch {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payCycleId         String    @unique @db.Uuid
  totalWithdrawn     Decimal   @db.Decimal(14, 2)
  totalFees          Decimal   @db.Decimal(14, 2)
  reportGeneratedAt  DateTime? @db.Timestamptz
  status             String    @default("pending") @db.VarChar(20)

  payCycle           PayCycle  @relation(fields: [payCycleId], references: [id])

  @@map("settlement_batches")
}